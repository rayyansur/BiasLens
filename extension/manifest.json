{
  "manifest_version": 3,
  "name": "BiasLens",
  "version": "1.0.0",
  "description": "Detect political bias and narrative framing on any page.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "BiasLens"
  }
}
